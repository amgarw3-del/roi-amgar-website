# העתק קובץ זה ל-.env.local ומלא את הערכים

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

GMAIL_USER=

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# AI — לפחות אחד מהשניים נדרש לדשבורד המנהלים
# Gemini: חינמי לחלוטין דרך https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Anthropic: בתשלום (אופציונלי, fallback)
ANTHROPIC_API_KEY=

# === אוטומציית הפצת דברי תורה (weekly-divrei cron) ===
# CRON_SECRET — מחרוזת אקראית, מוגדרת אוטומטית ע"י Vercel ב-Production
CRON_SECRET=

# Gmail — שליחת מייל אוטומטית (ערוץ ראשי, אמין)
# GMAIL_USER ו-GMAIL_APP_PASSWORD כבר מוגדרים בפרויקט (לשאלות וניוזלטר)
# NOTIFICATION_EMAIL — לאן לשלוח (default: GMAIL_USER עצמו)
NOTIFICATION_EMAIL=

# Green API — WhatsApp אוטומטי דרך החשבון של הרב (ערוץ ראשי, יציב)
# 1. הרשמה: https://green-api.com/en/
# 2. צור Instance מסוג "Developer" (חינמי, 50 הודעות/יום)
# 3. סרוק QR code עם וואטסאפ של הרב (פעם אחת)
# 4. העתק idInstance + apiTokenInstance מהדשבורד
RABBI_PHONE=972501234567
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN=

# CallMeBot — fallback ל-Green API (אופציונלי, best-effort)
# שלח ב-WhatsApp ל-+34 644 51 95 23 (Elina): "I allow callmebot to send me messages"
CALLMEBOT_API_KEY=

# URL הניוזלטר הציבורי באתר (להרשמה)
NEWSLETTER_URL=https://website-seven-kappa-25.vercel.app/#newsletter

# URL בסיס לאתר (לבניית קישורים)
NEXT_PUBLIC_SITE_URL=https://website-seven-kappa-25.vercel.app
